   "source": [
    "@tool(\"retriever_store\")\n",
    "def retriever_store(query ):\n",
    "    \"\"\"Use this tool to retrieve information (before 2025) about supreme court judgements from the vector store or law related sources.\"\"\"\n",
    "\n",
    "    print(\"Retriever Tool Called with query:\", query)\n",
    "\n",
    "    docs = retriever.invoke(query)\n",
    "    return \"\\n\\n\".join([doc.page_content for doc in docs])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "ae7ccf59",
   "metadata": {},
   "outputs": [],
   "source": [
    "@tool(\"wikipedia_search\")\n",
    "def wikipedia_search(query):\n",
    "    \"\"\"Use this tool to get a summary of information from Wikipedia if you didn't get enough information.\"\"\"\n",
    "    print(\"Wikipedia Search Tool Called with query:\", query)\n",
    "    wiki = WikipediaQueryRun(api_wrapper=WikipediaAPIWrapper(doc_content_chars_max=1000, top_k_results=1))\n",
    "    return wiki.invoke(query)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "a2c50429",
   "metadata": {},
   "outputs": [],
   "source": [
    "from langchain_tavily import TavilySearch\n",
    "\n",
    "\n",
    "@tool(\"websearch\")\n",
    "def websearch(query):\n",
    "    \"\"\"Use this tool to search the web for the latest information on a topic.\"\"\"\n",
    "    print(\"Web Search Tool Called with query:\", query)\n",
    "    tool = TavilySearch(\n",
    "        max_results=5,\n",
    "        topic='general',\n",
    "    )\n",
    "    \n",
    "    return tool.invoke({'query': query})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "b3780ae8",
   "metadata": {},
   "outputs": [],
   "source": [
    "tools = [retriever_store, wikipedia_search , websearch]\n",
    "\n",
    "react_node = create_agent(model=model, tools=tools)"
   ]
  },
